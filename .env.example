# Golem — Environment Variables
# Copy to .env and fill in values

# Network: mutinynet (default), mainnet, regtest
GOLEM_NETWORK=mutinynet

# Signer key (hex) — testnet only. Mainnet requires encrypted config via `golem init --encrypt`
# GOLEM_SIGNER_KEY=

# Password for encrypted wallet (mainnet). Set via `golem init --encrypt`
# GOLEM_PASSWORD=

# Voltage LND macaroon (base64-encoded) — required for Lightning payments via Boltz
# VOLTAGE_MACAROON=

# Telegram monitoring (optional) — enables /status, /txs, /vtxos, /health, /gateway commands
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
